{
  "title": "Observabilidade - Instagram",
  "timezone": "browser",
  "schemaVersion": 36,
  "refresh": "5s",
  "panels": [
    {
      "type": "stat",
      "title": "Usuários Logados Atualmente",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 0 },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus_ds"
          },
          "expr": "instagram_active_sessions",
          "legendFormat": "Ativos"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 80 }
            ]
          }
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Taxa de Requisições HTTP Backend",
      "gridPos": { "h": 8, "w": 16, "x": 8, "y": 0 },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus_ds"
          },
          "expr": "rate(http_server_requests_seconds_count{uri=~\"$endpoint\"}[15s])",
          "legendFormat": "{{uri}} - {{status}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "showPoints": "auto"
          }
        }
      }
    },
    {
      "type": "table",
      "title": "Usuários Online e Seus IPs",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus_ds"
          },
          "expr": "instagram_user_active_sessions == 1",
          "format": "table",
          "instant": true
        }
      ]
    },
    {
      "type": "logs",
      "title": "Logs de Mensagens (Tráfego de Rede / Payloads)",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 16 },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "instagram_loki"
          },
          "expr": "{app=\"instagram\"} |= \"PAYLOAD:\" |~ \"$endpoint\""
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "sortOrder": "Descending"
      }
    }
  ],
  "templating": {
    "list": [
      {
        "name": "endpoint",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus_ds"
        },
        "query": "label_values(http_server_requests_seconds_count, uri)",
        "includeAll": true,
        "multi": true,
        "allValue": ".*",
        "refresh": 1
      }
    ]
  }
}
